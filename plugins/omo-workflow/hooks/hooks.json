{
  "description": "OmO session mode hooks",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/omo_mode.py user-prompt-submit"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/omo_mode.py session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear|logout",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/omo_mode.py session-end"
          }
        ]
      }
    ]
  }
}
